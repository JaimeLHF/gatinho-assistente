generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  name          String
  createdAt     DateTime       @default(now())
  devices       Device[]
  events        Event[]
  refreshTokens RefreshToken[]
  firmwares     Firmware[]

  @@map("users")
}

model Device {
  id            String               @id @default(cuid())
  userId        String
  name          String
  tokenHash     String               @unique
  lastSeenAt    DateTime?
  createdAt     DateTime             @default(now())
  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  customization DeviceCustomization?

  @@index([userId])
  @@map("devices")
}

model DeviceCustomization {
  id       String @id @default(cuid())
  deviceId String @unique
  body     String @default("#D4A574")
  stripes  String @default("#8B5E3C")
  belly    String @default("#F5D4A0")
  outline  String @default("#000000")
  eyes     String @default("#FFFFFF")
  nose     String @default("#FF9B9B")
  bgType   String @default("solid")
  bgColor  String @default("#000000")
  device   Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@map("device_customizations")
}

model Event {
  id                 String      @id @default(cuid())
  userId             String
  title              String
  description        String?
  startsAt           DateTime
  durationMin        Int?
  alertMinutesBefore Int         @default(5)
  status             EventStatus @default(PENDING)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([startsAt])
  @@map("events")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Firmware {
  id        String   @id @default(cuid())
  version   String   @unique
  filename  String
  size      Int
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@map("firmwares")
}

enum EventStatus {
  PENDING
  DONE
  DISMISSED
}
